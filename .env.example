# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=code2resume.onrender.com,localhost,127.0.0.1

# Database (Render PostgreSQL — fill after provisioning)
# Leave commented to default to SQLite3)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Static files
STATIC_ROOT=staticfiles/

# Playwright browsers (0 = use system-installed browsers, 1 = use Playwright-managed browsers)
PLAYWRIGHT_BROWSERS_PATH=0

# Phase 2 — fill before enabling auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Code2Resume <noreply@code2resume.onrender.com>
EMAIL_VERIFICATION=optional

# Admin user (fill before first run)
DJANGO_SUPERUSER_EMAIL=admin@code2resume.dev
DJANGO_SUPERUSER_PASSWORD=your-strong-password-here
SITE_NAME=Code2Resume
RENDER_EXTERNAL_HOSTNAME=code2resume.onrender.com


# Cron job setup (replaces Celery for now)

# On Render's free tier you don't have shell access, but you can add a **Cron Job** service. Here's how:

# 1. In your Render dashboard, click **New → Cron Job**
# 2. Connect the same repo
# 3. Set the schedule to `0 1 * * *` (1am daily)
# 4. Set the command to:
# ```
# python manage.py aggregate_stats --days 1
# ```
# 5. Set environment to match your main service (same env vars)

# This runs independently of your web service and costs nothing on the free tier. It is exactly the same as Celery beat for this use case.